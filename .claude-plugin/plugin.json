{
  "id": "mcp-opencode",
  "name": "opencode",
  "displayName": "opencode",
  "description": "Query GitHub Copilot models (gpt-4.1, gpt-4o, o3, o4-mini) from inside Claude — get a second opinion without leaving your session.",
  "version": "1.0.0",
  "author": "kud",
  "repository": "https://github.com/kud/mcp-opencode",
  "npm": "@kud/mcp-opencode",
  "mcpConfig": {
    "transport": "stdio",
    "command": "npx",
    "args": ["-y", "@kud/mcp-opencode@latest"],
    "env": {
      "OPENCODE_MODEL_ALLOW": "${OPENCODE_MODEL_ALLOW:-github-copilot/*}",
      "OPENCODE_MODEL_BLOCK": "${OPENCODE_MODEL_BLOCK:-}"
    }
  },
  "skills": ["ask-opencode"]
}
